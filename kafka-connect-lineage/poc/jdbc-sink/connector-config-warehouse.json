{
  "name": "warehouse-sink",
  "config": {
    "connector.class": "io.debezium.connector.jdbc.JdbcSinkConnector",
    "connection.url": "jdbc:postgresql://postgres:5432/warehouse",
    "connection.username": "postgres",
    "connection.password": "postgres",
    "topics": "staging.public.users,staging.public.products,staging.public.orders,staging.public.order_items,staging.public.shipments",
    "schema.evolution": "basic",
    "insert.mode": "insert",
    "primary.key.mode": "none",
    "table.name.format": "${topic}",
    "transforms": "unwrap,openlineage,route",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "true",
    "transforms.openlineage.type": "io.aiven.kafka.connect.openlineage.OpenLineageSmt",
    "transforms.openlineage.connector.class": "io.debezium.connector.jdbc.JdbcSinkConnector",
    "transforms.openlineage.namespace": "warehouse-pipeline",
    "transforms.openlineage.transport.config.path": "/opt/openlineage/openlineage.yml",
    "transforms.openlineage.sink.namespace": "postgres://warehouse:5432",
    "transforms.openlineage.sink.dataset.database": "warehouse",
    "transforms.openlineage.kafka.bootstrap.servers": "kafka:9092",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "staging\\.public\\.(.*)",
    "transforms.route.replacement": "$1"
  }
}
